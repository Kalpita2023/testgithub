name: Frontend Feature Test
on:
  push:
    branches:
      - 'feature/*' ## run in feature branch
  pull_request:
    branches:
      - 'feature/*'

jobs:
  frontend-build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install Dependencies
        run: npm install

      - name: Run Tests
        run: npm test

      - name: Build
        run: npm run build
